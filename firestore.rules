rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // Helper functions
    // ============================================================

    function autenticado() {
      return request.auth != null;
    }

    function esAdmin() {
      // Verifica que exista un documento en superUser con ID = uid del usuario autenticado
      // NOTA: requiere que los documentos en superUser usen el uid como ID del documento
      return autenticado() && exists(/databases/$(database)/documents/superUser/$(request.auth.uid));
    }

    // ============================================================
    // Colecciones públicas de solo lectura (catálogo, sucursales)
    // ============================================================
    // Usamos wildcard {collection} porque "Sucursales de Foodmania"
    // contiene espacios y no se puede poner como literal en match.

    match /{collection}/{doc} {
      allow read: if collection in [
        'Sucursales de Foodmania', 'foodmaniaPedir', 'bebidas', 'salsas',
        'comidachina', 'comidarapida', 'hamburguesas', 'pollofrito',
        'promociones', 'supremos', 'surtidos', 'canjeManiaCoins'
      ];
      allow write: if false;
    }

    // ============================================================
    // Pedidos
    // ============================================================
    // Cualquiera puede crear (soporta usuarios anónimos)
    // Solo admins pueden leer, actualizar
    // No se permiten borrados

    match /pedidos/{pedidoId} {
      allow create: if false;
      allow read, update: if esAdmin();
      allow delete: if false;
    }

    // ============================================================
    // Clientes
    // ============================================================
    // Cada usuario solo puede leer/escribir su propio documento
    // Los admins pueden leer cualquier cliente y modificar solo el campo puntos
    // El ID del documento debe ser el uid del usuario

    match /clientes/{userId} {
      allow read: if autenticado() && (request.auth.uid == userId || esAdmin());
      allow create: if autenticado() && request.auth.uid == userId;
      allow update: if (autenticado() && request.auth.uid == userId) ||
                     (esAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['puntos', 'ultimaCompra', 'ultimaGananciaCoins']));
      allow delete: if false;
    }

    // ============================================================
    // SuperUser (Administradores)
    // ============================================================
    // Lectura: cualquier usuario autenticado
    // Escritura: solo admins (requiere que el documento exista previamente)

    match /superUser/{userId} {
      allow read: if autenticado();
      allow write: if esAdmin();
    }

    // ============================================================
    // Audit Logs
    // ============================================================
    // Solo admins pueden crear/leer logs de auditoría

    match /auditLogs/{logId} {
      allow read, create: if esAdmin();
      allow update, delete: if false;
    }

    // ============================================================
    // Default: denegar todo lo demás
    // ============================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
